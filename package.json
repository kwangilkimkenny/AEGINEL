{
  "name": "@aegis-personal/extension",
  "private": true,
  "version": "1.1.3",
  "type": "module",
  "description": "Aegis Personal Chrome Extension - AI Privacy Guard",
  "scripts": {
    "dev": "pnpm prepare:models && vite",
    "build": "pnpm prepare:models && tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "verify:i18n": "npx tsx scripts/verify-i18n.ts",
    "prepare:models": "mkdir -p public/ort && cp node_modules/@huggingface/transformers/dist/ort-wasm-simd-threaded.jsep.mjs public/ort/ && cp node_modules/@huggingface/transformers/dist/ort-wasm-simd-threaded.jsep.wasm public/ort/"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.28",
    "@playwright/test": "^1.58.2",
    "@types/chrome": "^0.0.287",
    "@types/node": "^25.4.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^4.0.18"
  }
}
